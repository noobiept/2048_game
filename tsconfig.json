{
  "exclude": [
    "release",
    "typings",
    "build",
    "dist",
    "node_modules",
    "public"
  ],
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "useDefineForClassFields": true
  },
  "include": [
    "scripts/**/*.ts"
  ],
  "files": [
    "scripts/globals.d.ts"
  ]
}
