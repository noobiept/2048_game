        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "globals": "^17.5.0",
        "prettier": "^3.8.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.1",
        "vite": "^8.0.10",
        "vitest": "^4.1.5"
    },
    "dependencies": {
        "@drk4/game-engine": "^2.0.0"
    }
}
