{
    "name": "2048_game",
    "description": "A sliding block puzzle game.",
    "version": "2.0.1",
    "license": "AGPL-3.0",
    "packageManager": "pnpm@10.33.2",
    "scripts": {
        "lint": "eslint source",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "typecheck": "tsc --noEmit",
